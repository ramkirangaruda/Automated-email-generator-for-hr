# Copy this file to .env and fill in real values.
# .env is gitignored - never commit it.
#
# --dry-run works without any SMTP credentials at all.

SMTP_HOST=mail.ifocussystec.in
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=itsupport@ifocussystec.com
SMTP_PASSWORD=
SMTP_FROM_NAME=HR Support

# HR Portal (portal_app.py / run_portal.py)
# Shared password HR (and anyone else) types in to open the portal.
PORTAL_PASSWORD=

# Random long string used to sign session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Keep it stable - if it changes, everyone gets logged out.
SECRET_KEY=
